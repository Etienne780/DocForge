{
  "name": "DocForge",
  "version": "1.0.0",
  "description": "Tool for creating structured documentation",
  "license": "MIT",
  "author": "Etienne780",
  "type": "module",
  "main": "main/ElectronMain.js",
  "build": {
    "appId": "com.Etienne780.DocForge",
    "productName": "DocForge",
    "icon": "assets/icons/logo",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": ["AppImage"]
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "draft"
      }
    ],
    "files": [
      "main/**/*",
      "preload/**/*",
      "renderer/dist/**/*",
      "package.json"
    ]
},
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev": "npm-run-all -p dev:renderer dev:electron",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production electron .",
    "dist": "electron-builder",
    "help": "echo \"use 'dev' for development\" && echo \"use 'build' for production build\" && echo \"use 'start' for electron-forge start\""
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@rollup/plugin-alias": "^6.0.0",
    "cross-env": "^7.0.3",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "npm-run-all": "^4.1.5",
    "vite": "^8.0.3",
    "vite-plugin-static-copy": "^4.0.0"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.8.3"
  }
}
